# Tableau Cloud Credentials
# Rename this file to .env and fill in your values before running any scripts.
# Never commit the .env file to version control — it should only exist locally.

# Your Tableau Cloud server URL (no trailing slash)
# Example: https://prod-useast-a.online.tableau.com
TABLEAU_SERVER_URL=

# Your site name as it appears in the Tableau Cloud URL
# Example: if your URL is https://prod-useast-a.online.tableau.com/#/site/mysite/...
# then your site ID is: mysite
TABLEAU_SITE_ID=

# Personal Access Token (PAT) name — created in Tableau Cloud under
# Account Settings > Personal Access Tokens
TABLEAU_PAT_NAME=

# Personal Access Token value — only shown once at creation time
# If you've lost it, delete the old token and generate a new one
TABLEAU_PAT_VALUE=
